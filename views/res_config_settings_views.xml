<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_woo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.digitalnatie.woo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="WooCommerce" name="digitalnatie_woocommerce">
                    <block title="WooCommerce API Connection">
                        <setting string="Store URL"
                                 help="Base URL of your WooCommerce store (e.g. https://yourstore.com)">
                            <field name="woo_store_url" placeholder="https://yourstore.com"/>
                        </setting>
                        <setting string="Consumer Key">
                            <field name="woo_consumer_key"/>
                        </setting>
                        <setting string="Consumer Secret">
                            <field name="woo_consumer_secret" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
