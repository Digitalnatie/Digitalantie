<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_woo" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.digitalnatie.woo</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="WooCommerce" name="woo">
                    <group>
                        <field name="woo_instance_id"/>
                        <field name="woo_customer_id" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
