<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_digitalnatie_woo_import_orders" model="ir.cron">
        <field name="name">WooCommerce: Import Orders</field>
        <field name="model_id" ref="model_digitalnatie_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model.cron_import_orders()</field>
        <field name="interval_type">minutes</field>
        <field name="interval_number">15</field>
        <field name="active">False</field>
    </record>

    <record id="ir_cron_digitalnatie_woo_import_products" model="ir.cron">
        <field name="name">WooCommerce: Import Products</field>
        <field name="model_id" ref="model_digitalnatie_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model.cron_import_products()</field>
        <field name="interval_type">hours</field>
        <field name="interval_number">6</field>
        <field name="active">False</field>
    </record>

    <record id="ir_cron_digitalnatie_woo_sync_inventory" model="ir.cron">
        <field name="name">WooCommerce: Export Inventory (Odoo -&gt; WooCommerce)</field>
        <field name="model_id" ref="model_digitalnatie_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_inventory()</field>
        <field name="interval_type">minutes</field>
        <field name="interval_number">30</field>
        <field name="active">False</field>
    </record>

    <record id="ir_cron_digitalnatie_woo_sync_prices" model="ir.cron">
        <field name="name">WooCommerce: Export Prices (Odoo -&gt; WooCommerce)</field>
        <field name="model_id" ref="model_digitalnatie_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_prices()</field>
        <field name="interval_type">hours</field>
        <field name="interval_number">6</field>
        <field name="active">False</field>
    </record>

    <record id="ir_cron_digitalnatie_woo_sync_fulfillment" model="ir.cron">
        <field name="name">WooCommerce: Sync Fulfillment Status (Bi-directional)</field>
        <field name="model_id" ref="model_digitalnatie_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_fulfillment()</field>
        <field name="interval_type">minutes</field>
        <field name="interval_number">30</field>
        <field name="active">False</field>
    </record>

    <record id="ir_cron_digitalnatie_woo_cleanup_logs" model="ir.cron">
        <field name="name">WooCommerce: Cleanup Old Sync Logs</field>
        <field name="model_id" ref="model_digitalnatie_woo_log"/>
        <field name="state">code</field>
        <field name="code">model.cron_cleanup_logs()</field>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="active">True</field>
    </record>
</odoo>
