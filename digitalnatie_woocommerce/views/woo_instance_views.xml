<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_digitalnatie_woo_instance_tree" model="ir.ui.view">
        <field name="name">digitalnatie.woo.instance.list</field>
        <field name="model">digitalnatie.woo.instance</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Instances">
                <field name="name"/>
                <field name="api_url"/>
                <field name="is_active"/>
                <field name="webhook_enabled"/>
                <field name="last_sync_products"/>
                <field name="last_sync_orders"/>
            </list>
        </field>
    </record>

    <record id="view_digitalnatie_woo_instance_form" model="ir.ui.view">
        <field name="name">digitalnatie.woo.instance.form</field>
        <field name="model">digitalnatie.woo.instance</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Instance">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object"/>
                    <button name="action_import_products" string="Import Products" type="object"/>
                    <button name="action_export_products" string="Export Products" type="object"/>
                    <button name="action_import_customers" string="Import Customers" type="object"/>
                    <button name="action_import_orders" string="Import Orders" type="object"/>
                    <button name="action_link_products" string="Link Products" type="object"/>
                    <button name="action_sync_inventory" string="Export Inventory" type="object"/>
                    <button name="action_import_inventory_recovery" string="Import Stock (Recovery)" type="object"
                            confirm="This overwrites Odoo on-hand quantities with WooCommerce stock. Continue?"/>
                    <button name="action_sync_prices" string="Export Prices" type="object"/>
                    <button name="action_import_prices_recovery" string="Import Prices (Recovery)" type="object"
                            confirm="This overwrites Odoo sales prices with WooCommerce prices. Continue?"/>
                    <button name="action_sync_fulfillment" string="Sync Fulfillment" type="object"/>
                    <button name="action_register_webhooks" string="Register Webhooks" type="object"/>
                    <button name="action_full_sync" string="Full Sync" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_view_logs"
                                type="object" icon="fa-list-alt">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="is_active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group>
                            <field name="api_url"/>
                        </group>
                    </group>
                    <group string="Credentials">
                        <group>
                            <field name="consumer_key" password="True"/>
                            <field name="consumer_secret" password="True"/>
                            <field name="verify_ssl"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sync Settings" name="sync_settings">
                            <group>
                                <group string="Direction per Object">
                                    <field name="sync_product_direction"/>
                                    <field name="sync_customer_direction"/>
                                    <field name="sync_order_direction"/>
                                    <field name="sync_inventory_direction"/>
                                    <field name="sync_price_direction"/>
                                    <field name="sync_fulfillment_direction"/>
                                </group>
                                <group string="Order Options">
                                    <field name="import_only_completed_orders"/>
                                    <field name="confirm_imported_orders"/>
                                </group>
                            </group>
                        </page>
                        <page string="Webhooks" name="webhooks">
                            <group>
                                <field name="webhook_enabled"/>
                                <field name="webhook_secret" password="True"/>
                                <field name="webhook_url" readonly="1"/>
                            </group>
                            <div class="text-muted">
                                Use "Register Webhooks" to automatically create the
                                order, product and customer webhooks inside WooCommerce.
                            </div>
                        </page>
                        <page string="Meta Field Mappings" name="meta">
                            <field name="meta_mapping_ids">
                                <list editable="bottom">
                                    <field name="woo_object"/>
                                    <field name="woo_meta_key"/>
                                    <field name="odoo_field_name"/>
                                    <field name="direction"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Last Synchronisations" name="last_sync">
                            <group>
                                <field name="last_sync_products" readonly="1"/>
                                <field name="last_sync_orders" readonly="1"/>
                                <field name="last_sync_customers" readonly="1"/>
                                <field name="last_sync_stock" readonly="1"/>
                                <field name="last_sync_prices" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_digitalnatie_woo_instance" model="ir.actions.act_window">
        <field name="name">WooCommerce Instances</field>
        <field name="res_model">digitalnatie.woo.instance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
