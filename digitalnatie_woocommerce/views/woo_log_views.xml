<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_digitalnatie_woo_log_tree" model="ir.ui.view">
        <field name="name">digitalnatie.woo.log.list</field>
        <field name="model">digitalnatie.woo.log</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Sync Logs" create="false"
                  decoration-danger="level == 'error'"
                  decoration-warning="level == 'warning'">
                <field name="create_date"/>
                <field name="instance_id"/>
                <field name="operation"/>
                <field name="level"/>
                <field name="summary"/>
                <field name="woo_ref" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_digitalnatie_woo_log_form" model="ir.ui.view">
        <field name="name">digitalnatie.woo.log.form</field>
        <field name="model">digitalnatie.woo.log</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Sync Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="instance_id"/>
                            <field name="operation"/>
                            <field name="level"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="woo_ref"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                        </group>
                    </group>
                    <field name="summary"/>
                    <field name="message"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_digitalnatie_woo_log_search" model="ir.ui.view">
        <field name="name">digitalnatie.woo.log.search</field>
        <field name="model">digitalnatie.woo.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="summary"/>
                <field name="woo_ref"/>
                <field name="instance_id"/>
                <filter name="errors" string="Errors" domain="[('level','=','error')]"/>
                <filter name="warnings" string="Warnings" domain="[('level','=','warning')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_instance" string="Instance"
                            context="{'group_by': 'instance_id'}"/>
                    <filter name="group_operation" string="Operation"
                            context="{'group_by': 'operation'}"/>
                    <filter name="group_level" string="Level"
                            context="{'group_by': 'level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_digitalnatie_woo_log" model="ir.actions.act_window">
        <field name="name">WooCommerce Sync Logs</field>
        <field name="res_model">digitalnatie.woo.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_errors': 0}</field>
    </record>
</odoo>
